generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model admin {
  id_admin   Int     @id @default(autoincrement())
  id_user    Int?    @unique(map: "Admin_id_user_key")
  nama_admin String?
  email      String?
  avatar     String?
  is_active  Boolean @default(true)
  users      users?  @relation(fields: [id_user], references: [user_id], map: "Admin_id_user_fkey")
}

model buktikegiatan {
  id_bukti          Int                @id @default(autoincrement())
  id_kegiatan       Int?
  file_path         String
  tipe_file         String?
  ukuran_file       Int?
  upload_at         DateTime           @default(now())
  kegiatanmahasiswa kegiatanmahasiswa? @relation(fields: [id_kegiatan], references: [id_kegiatan], map: "BuktiKegiatan_id_kegiatan_fkey")

  @@index([id_kegiatan], map: "BuktiKegiatan_id_kegiatan_fkey")
}

model cpl {
  id_cpl    Int     @id @default(autoincrement())
  kode_cpl  String
  deskripsi String?
}

model icpkategori {
  id_icp       Int            @id @default(autoincrement())
  nama_indo    String
  nama_eng     String
  bobot_poin   Int
  icpmahasiswa icpmahasiswa[]
}

model icpmahasiswa {
  id_icp_mahasiswa Int          @id @default(autoincrement())
  id_mahasiswa     Int?
  id_icp           Int?
  total_poin       Int?
  icpkategori      icpkategori? @relation(fields: [id_icp], references: [id_icp], map: "IcpMahasiswa_id_icp_fkey")
  mahasiswa        mahasiswa?   @relation(fields: [id_mahasiswa], references: [id_mahasiswa], map: "IcpMahasiswa_id_mahasiswa_fkey")

  @@index([id_icp], map: "IcpMahasiswa_id_icp_fkey")
  @@index([id_mahasiswa], map: "IcpMahasiswa_id_mahasiswa_fkey")
}

model jenisaktivitas {
  id_jenis          Int                 @id @default(autoincrement())
  nama_indo         String
  nama_eng          String
  status            Boolean             @default(true)
  kegiatanmahasiswa kegiatanmahasiswa[]
}

model kategoriaktivitas {
  id_kategori       Int                 @id @default(autoincrement())
  nama_indo         String
  nama_eng          String
  status            Boolean             @default(true)
  kegiatanmahasiswa kegiatanmahasiswa[]
}

model kegiatanmahasiswa {
  id_kegiatan       Int                                 @id @default(autoincrement())
  id_mahasiswa      Int?
  id_jenis          Int?
  id_kategori       Int?
  id_kelompok       Int?
  id_level          Int?
  id_posisi         Int?
  nama_kegiatan     String
  nama_kegiatan_eng String?
  penyelenggara     String?
  lokasi            String?
  tanggal_kegiatan  DateTime?
  periode_kegiatan  String?
  tingkat_prestasi  String?
  peringkat         String?
  status_verifikasi kegiatanmahasiswa_status_verifikasi @default(diproses)
  catatan_admin     String?
  buktikegiatan     buktikegiatan[]
  jenisaktivitas    jenisaktivitas?                     @relation(fields: [id_jenis], references: [id_jenis], map: "KegiatanMahasiswa_id_jenis_fkey")
  kategoriaktivitas kategoriaktivitas?                  @relation(fields: [id_kategori], references: [id_kategori], map: "KegiatanMahasiswa_id_kategori_fkey")
  kelompokaktivitas kelompokaktivitas?                  @relation(fields: [id_kelompok], references: [id_kelompok], map: "KegiatanMahasiswa_id_kelompok_fkey")
  levelkegiatan     levelkegiatan?                      @relation(fields: [id_level], references: [id_level], map: "KegiatanMahasiswa_id_level_fkey")
  mahasiswa         mahasiswa?                          @relation(fields: [id_mahasiswa], references: [id_mahasiswa], map: "KegiatanMahasiswa_id_mahasiswa_fkey")
  posisikegiatan    posisikegiatan?                     @relation(fields: [id_posisi], references: [id_posisi], map: "KegiatanMahasiswa_id_posisi_fkey")

  @@index([id_jenis], map: "KegiatanMahasiswa_id_jenis_fkey")
  @@index([id_kategori], map: "KegiatanMahasiswa_id_kategori_fkey")
  @@index([id_kelompok], map: "KegiatanMahasiswa_id_kelompok_fkey")
  @@index([id_level], map: "KegiatanMahasiswa_id_level_fkey")
  @@index([id_mahasiswa], map: "KegiatanMahasiswa_id_mahasiswa_fkey")
  @@index([id_posisi], map: "KegiatanMahasiswa_id_posisi_fkey")
}

model kelompokaktivitas {
  id_kelompok       Int                 @id @default(autoincrement())
  nama_indo         String
  nama_eng          String
  status            Boolean             @default(true)
  kegiatanmahasiswa kegiatanmahasiswa[]
}

model levelkegiatan {
  id_level          Int                 @id @default(autoincrement())
  nama_level        String
  kegiatanmahasiswa kegiatanmahasiswa[]
}

model mahasiswa {
  id_mahasiswa      Int                   @id @default(autoincrement())
  id_user           Int?
  nim               String
  nama              String
  id_prodi          Int?
  angkatan          Int?
  email             String?
  foto_profil       String?
  status_skpi       mahasiswa_status_skpi @default(belum)
  tempat_lahir      String?
  tgl_lahir         DateTime?
  tanggal_masuk     DateTime?
  tanggal_lulus     DateTime?
  nomor_ijazah      String?
  gelar             String?
  gelar_eng         String?
  icpmahasiswa      icpmahasiswa[]
  kegiatanmahasiswa kegiatanmahasiswa[]
  programstudi      programstudi?         @relation(fields: [id_prodi], references: [id_prodi], map: "Mahasiswa_id_prodi_fkey")
  users             users?                @relation(fields: [id_user], references: [user_id], map: "Mahasiswa_id_user_fkey")
  pengajuanskpi     pengajuanskpi[]
  riwayatskpi       riwayatskpi[]
  skpi              skpi[]

  @@index([id_prodi], map: "Mahasiswa_id_prodi_fkey")
  @@index([id_user], map: "Mahasiswa_id_user_fkey")
}

model notifikasi {
  id_notifikasi Int      @id @default(autoincrement())
  id_user       Int?
  judul         String
  pesan         String
  status_baca   Boolean  @default(false)
  created_at    DateTime @default(now())
  users         users?   @relation(fields: [id_user], references: [user_id], map: "Notifikasi_id_user_fkey")

  @@index([id_user], map: "Notifikasi_id_user_fkey")
}

model pengajuanskpi {
  id_pengajuan      Int                            @id @default(autoincrement())
  id_mahasiswa      Int?
  tanggal_pengajuan DateTime?
  status_pengajuan  pengajuanskpi_status_pengajuan @default(menunggu)
  catatan_admin     String?
  mahasiswa         mahasiswa?                     @relation(fields: [id_mahasiswa], references: [id_mahasiswa], map: "PengajuanSkpi_id_mahasiswa_fkey")

  @@index([id_mahasiswa], map: "PengajuanSkpi_id_mahasiswa_fkey")
}

model periodeakademik {
  id_periode   Int                      @id @default(autoincrement())
  nama_periode String
  semester     periodeakademik_semester
  status       Boolean                  @default(true)
}

model posisikegiatan {
  id_posisi         Int                 @id @default(autoincrement())
  nama_posisi       String
  kegiatanmahasiswa kegiatanmahasiswa[]
}

model programstudi {
  id_prodi   Int         @id @default(autoincrement())
  nama_prodi String
  fakultas   String
  mahasiswa  mahasiswa[]
}

model riwayatskpi {
  id_riwayat       Int        @id @default(autoincrement())
  id_skpi          Int?
  id_mahasiswa     Int?
  tanggal_generate DateTime?
  keterangan       String?
  mahasiswa        mahasiswa? @relation(fields: [id_mahasiswa], references: [id_mahasiswa], map: "RiwayatSkpi_id_mahasiswa_fkey")
  skpi             skpi?      @relation(fields: [id_skpi], references: [id_skpi], map: "RiwayatSkpi_id_skpi_fkey")

  @@index([id_mahasiswa], map: "RiwayatSkpi_id_mahasiswa_fkey")
  @@index([id_skpi], map: "RiwayatSkpi_id_skpi_fkey")
}

model sectiontemplate {
  id_section   Int           @id @default(autoincrement())
  id_template  Int?
  judul_indo   String
  judul_eng    String
  urutan       Int
  status       Boolean       @default(true)
  templateskpi templateskpi? @relation(fields: [id_template], references: [id_template], map: "SectionTemplate_id_template_fkey")

  @@index([id_template], map: "SectionTemplate_id_template_fkey")
}

model skpi {
  id_skpi        Int           @id @default(autoincrement())
  id_mahasiswa   Int?
  nomor_skpi     String?
  tanggal_terbit DateTime?
  file_skpi      String?
  versi          Int?
  status         skpi_status   @default(draft)
  riwayatskpi    riwayatskpi[]
  mahasiswa      mahasiswa?    @relation(fields: [id_mahasiswa], references: [id_mahasiswa], map: "Skpi_id_mahasiswa_fkey")

  @@index([id_mahasiswa], map: "Skpi_id_mahasiswa_fkey")
}

model tandatangandigital {
  id_ttd       Int     @id @default(autoincrement())
  nama_pejabat String
  jabatan      String
  file_ttd     String
  status       Boolean @default(true)
}

model tailscale_config {
  id           Int      @id @default(autoincrement())
  api_url      String   @default("")
  api_key      String   @default("")
  mahasiswa_ep String   @default("/api/users/by-role/mahasiswa")
  icp_ep       String   @default("/api/icp/balance/ranking")
  updated_at   DateTime @updatedAt
  updated_by   Int?
}

model templateskpi {
  id_template     Int               @id @default(autoincrement())
  nama_template   String
  status          Boolean           @default(true)
  created_at      DateTime          @default(now())
  sectiontemplate sectiontemplate[]
}

model users {
  user_id     Int               @id @default(autoincrement())
  username    String
  password    String
  role        users_role
  email       String?
  status_akun users_status_akun @default(aktif)
  created_at  DateTime          @default(now())
  updated_at  DateTime
  admin       admin?
  mahasiswa   mahasiswa[]
  notifikasi  notifikasi[]
}

model Dokumentasi {
  id          Int       @id @default(autoincrement())
  judul       String    @db.VarChar(191)
  kategori    String    @db.VarChar(50)
  deskripsi   String?   @db.VarChar(500)
  konten      String?   @db.MediumText
  file_url    String?   @db.VarChar(255)
  diagram_xml String?   @db.MediumText     // MEDIUMTEXT (16MB): XML draw.io hasil import bisa >64KB
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
}


enum periodeakademik_semester {
  Ganjil
  Genap
}

enum pengajuanskpi_status_pengajuan {
  menunggu
  disetujui
  ditolak
}

enum users_role {
  mahasiswa
  admin
}

enum users_status_akun {
  aktif
  nonaktif
}

enum skpi_status {
  draft
  resmi
}

enum mahasiswa_status_skpi {
  belum
  diajukan
  direvisi
  diterbitkan
}

enum kegiatanmahasiswa_status_verifikasi {
  diproses
  disetujui
  ditolak
  revisi
}
