{
  "name": "skpi-backend",
  "version": "1.0.0",
  "description": "Backend API untuk Sistem SKPI - Institut Shanti Bhuana",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
