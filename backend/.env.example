# Backend environment variables
# Copy this file to .env and sesuaikan dengan MySQL lokal Anda.

PORT=5000

# Prisma database connection
DATABASE_URL="mysql://root:@localhost:3306/skpi_db"

# MySQL untuk session store
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=skpi_db

# Session secret untuk express-session
SESSION_SECRET=skpi-dev-secret

# Mode aplikasi. WAJIB "production" saat deploy di Railway agar cookie session
# diset secure + sameSite=none (syarat login lintas domain frontend↔backend).
NODE_ENV=development

# URL frontend yang diizinkan untuk CORS. Boleh beberapa URL dipisah koma.
# Produksi contoh: FRONTEND_URL=https://sistem-skpi-frontend-production.up.railway.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Google reCAPTCHA — SECRET key (rahasia, hanya di server). Ambil dari
# https://www.google.com/recaptcha/admin. Site key publik diisi di frontend.
# Kosongkan untuk MENONAKTIFKAN verifikasi captcha (mis. saat dev/demo).
RECAPTCHA_SECRET_KEY="6LepFUstAAAAAO-MePDwsrUvi2p93RIM9XCaIHTA"
