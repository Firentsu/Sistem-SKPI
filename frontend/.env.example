# URL backend SKPI. NEXT_PUBLIC_* di-inline saat `next build`, jadi di Railway
# WAJIB diisi di Variables service frontend (bukan hanya di file ini).
# Produksi contoh: NEXT_PUBLIC_API_URL=https://sistem-skpi-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:5000

# ICP System (Integrity Credit Point) — isi setelah sistem ICP di-hosting
NEXT_PUBLIC_ICP_API_URL=

# Google reCAPTCHA — SITE key (publik, aman tampil di browser).
# Ambil dari https://www.google.com/recaptcha/admin. Secret key ada di backend/.env.
# Kosongkan untuk MENONAKTIFKAN captcha di halaman login.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="6LepFUstAAAAAHweji5CIqMY2ucPy6M-uFNfUHOr"