# ============================================
# SICP — Environment Variables (CONTOH)
# Copy ke .env lalu isi nilai sebenarnya
# ============================================
PORT=5001

# JWT — ganti dengan random string panjang & rahasia
JWT_SECRET=GANTI_DENGAN_SECRET_RANDOM_ANDA

# Database MariaDB/MySQL
DB_HOST=localhost
DB_USER=sicp_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_DB
DB_NAME=db_sicp
